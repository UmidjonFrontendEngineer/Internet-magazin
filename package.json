{
  "name": "solito-blank",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@next/swc-linux-x64-gnu": "^16.2.10",
    "@next/swc-linux-x64-musl": "^16.2.10",
    "@types/react": "^18.2.21",
    "eslint": "^8.21.0",
    "turbo": "^2.4.4",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "native": "cd apps/expo && yarn start",
    "web": "cd apps/next && yarn next"
  },
  "packageManager": "yarn@4.7.0",
  "eslintConfig": {
    "extends": "next",
    "settings": {
      "next": {
        "rootDir": "apps/next/"
      }
    },
    "root": true
  },
  "prettier": {
    "semi": false,
    "useTabs": false,
    "tabWidth": 2,
    "singleQuote": true
  },
  "dependencies": {
    "expo-blur": "^56.0.3",
    "expo-linear-gradient": "^56.0.4",
    "react-native-gesture-handler": "^3.0.2",
    "react-native-reanimated": "^4.5.0",
    "react-native-safe-area-context": "^5.8.0"
  }
}
